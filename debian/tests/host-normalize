#!/bin/bash
# Test for Host header normalization with absolute URI requests
# RFC 9112 Section 3.2.2: When using absolute-form request-target,
# the server MUST ignore the Host header and use the URI host instead.

set -e

TMPDIR=$(mktemp -d)

cleanup() {
    [ -f "$TMPDIR/nginx.pid" ] && kill $(cat $TMPDIR/nginx.pid) 2>/dev/null || true
    sleep 0.3
    rm -rf "$TMPDIR"
}
trap cleanup EXIT

PORT=18771

# Ensure module is loaded
MODULE_SO="/usr/lib/nginx/modules/ngx_http_host_normalize_module.so"
if [ -f "$MODULE_SO" ]; then
    LOAD_MODULE="load_module $MODULE_SO;"
    echo "Module found: $MODULE_SO"
else
    echo "ERROR: Module not found at $MODULE_SO"
    echo "Available modules:"
    ls -la /usr/lib/nginx/modules/ 2>/dev/null || echo "  (none)"
    exit 1
fi

# Create nginx config that returns $host in response body
cat > $TMPDIR/nginx.conf << EOF
$LOAD_MODULE
worker_processes 1;
daemon off;
pid $TMPDIR/nginx.pid;
error_log $TMPDIR/nginx-error.log info;
events { worker_connections 64; }
http {
    access_log off;
    server {
        listen $PORT;
        server_name secure.example.com;
        location / {
            add_header Content-Type text/plain;
            return 200 "HOST=\$host\nHTTP_HOST=\$http_host\nSERVER_NAME=\$server_name\n";
        }
    }
}
EOF

# Test nginx config first
echo "Testing nginx configuration..."
/usr/sbin/nginx -t -c $TMPDIR/nginx.conf 2>&1 || { echo "Nginx config test failed"; exit 1; }

# Start nginx
echo "Starting nginx..."
/usr/sbin/nginx -c $TMPDIR/nginx.conf &
sleep 0.5

# Verify nginx is running
if ! pgrep -f "nginx.*$TMPDIR" > /dev/null; then
    echo "ERROR: nginx failed to start"
    cat $TMPDIR/nginx-error.log 2>/dev/null || true
    exit 1
fi
echo "Nginx started successfully"

echo "=== Test: Host Header Normalization with Absolute URI ==="
echo ""
echo "Attack scenario: Sending absolute URI with spoofed Host header"
echo "  curl --request-target 'http://secure.example.com/'"
echo "       -H 'Host: malicious.attacker.com' http://127.0.0.1:$PORT/"
echo ""

# Disable set -e for curl to capture errors properly
set +e
RESULT=$(curl -s --max-time 5 --request-target 'http://secure.example.com/' \
    -H 'Host: malicious.attacker.com' http://127.0.0.1:$PORT/ 2>&1)
CURL_RC=$?
set -e

if [ $CURL_RC -ne 0 ]; then
    echo "ERROR: curl failed with exit code $CURL_RC"
    echo "Result: $RESULT"
    # Check if --request-target is supported
    if echo "$RESULT" | grep -q "option --request-target"; then
        echo "curl does not support --request-target, trying alternative method..."
        # Alternative: use printf and netcat
        set +e
        RESULT=$(printf 'GET http://secure.example.com/ HTTP/1.1\r\nHost: malicious.attacker.com\r\nConnection: close\r\n\r\n' | \
            nc -q1 127.0.0.1 $PORT 2>&1)
        CURL_RC=$?
        set -e
        if [ $CURL_RC -ne 0 ]; then
            echo "ERROR: netcat also failed"
            exit 1
        fi
    else
        exit 1
    fi
fi

# Debug: show raw result
echo "Raw response:"
echo "$RESULT"
echo "---"

# Parse results (use sed for compatibility)
# $host is what nginx uses internally (should be normalized by our module)
# $http_host is the original Host header value
HOST=$(echo "$RESULT" | sed -n 's/^HOST=//p' | head -1)
HTTP_HOST=$(echo "$RESULT" | sed -n 's/^HTTP_HOST=//p' | head -1)
SERVER_NAME=$(echo "$RESULT" | sed -n 's/^SERVER_NAME=//p' | head -1)

echo "Nginx variables:"
echo "  HOST (\$host)=$HOST"
echo "  HTTP_HOST (\$http_host)=$HTTP_HOST"
echo "  SERVER_NAME (\$server_name)=$SERVER_NAME"
echo ""

# The module normalizes $http_host to match the URI host
if [ "$HTTP_HOST" = "secure.example.com" ]; then
    echo "PASS: \$http_host correctly normalized to URI host (RFC 9112 compliant)"
    exit 0
elif [ "$HTTP_HOST" = "malicious.attacker.com" ]; then
    echo "FAIL: \$http_host contains spoofed value (VULNERABLE)"
    exit 1
else
    echo "UNKNOWN: HTTP_HOST=$HTTP_HOST"
    echo "Nginx error log:"
    cat $TMPDIR/nginx-error.log 2>/dev/null | tail -20 || echo "(empty)"
    exit 2
fi
