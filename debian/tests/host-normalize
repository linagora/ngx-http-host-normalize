#!/bin/bash
# Test for Host header normalization with absolute URI requests
# RFC 9112 Section 3.2.2: When using absolute-form request-target,
# the server MUST ignore the Host header and use the URI host instead.

set -e

TMPDIR=$(mktemp -d)

cleanup() {
    [ -f "$TMPDIR/nginx.pid" ] && kill $(cat $TMPDIR/nginx.pid) 2>/dev/null || true
    [ -n "$FCGI_PID" ] && kill $FCGI_PID 2>/dev/null || true
    sleep 0.3
    rm -rf "$TMPDIR"
}
trap cleanup EXIT

# Create FastCGI server that echoes HTTP_HOST
cat > $TMPDIR/fcgi-echo.pl << 'PERL'
#!/usr/bin/env perl
use strict;
use FCGI;
my $socket = FCGI::OpenSocket($ARGV[0], 5);
my $request = FCGI::Request(\*STDIN, \*STDOUT, \*STDERR, \%ENV, $socket);
while ($request->Accept() >= 0) {
    print "Content-Type: text/plain\r\n\r\n";
    print "HTTP_HOST=$ENV{HTTP_HOST}\n";
    print "HOST=$ENV{RHOST}\n";
    print "SERVER_NAME=$ENV{SERVER_NAME}\n";
}
PERL
chmod +x $TMPDIR/fcgi-echo.pl

PORT=18771

# Ensure module is loaded
MODULE_SO="/usr/lib/nginx/modules/ngx_http_host_normalize_module.so"
if [ -f "$MODULE_SO" ]; then
    LOAD_MODULE="load_module $MODULE_SO;"
    echo "Module found: $MODULE_SO"
else
    echo "ERROR: Module not found at $MODULE_SO"
    echo "Available modules:"
    ls -la /usr/lib/nginx/modules/ 2>/dev/null || echo "  (none)"
    exit 1
fi

cat > $TMPDIR/nginx.conf << EOF
$LOAD_MODULE
worker_processes 1;
daemon off;
pid $TMPDIR/nginx.pid;
error_log /dev/null;
events { worker_connections 64; }
http {
    access_log off;
    server {
        listen $PORT;
        server_name secure.example.com;
        location / {
            fastcgi_pass unix:$TMPDIR/fcgi.sock;
            include /etc/nginx/fastcgi_params;
            fastcgi_param RHOST \$host;
        }
    }
}
EOF

# Start FastCGI server
perl $TMPDIR/fcgi-echo.pl $TMPDIR/fcgi.sock &
FCGI_PID=$!
sleep 0.5

# Test nginx config first
echo "Testing nginx configuration..."
/usr/sbin/nginx -t -c $TMPDIR/nginx.conf 2>&1 || { echo "Nginx config test failed"; exit 1; }

# Start nginx
echo "Starting nginx..."
/usr/sbin/nginx -c $TMPDIR/nginx.conf &
sleep 0.5

# Verify nginx is running
if ! pgrep -f "nginx.*$TMPDIR" > /dev/null; then
    echo "ERROR: nginx failed to start"
    cat $TMPDIR/nginx.conf
    exit 1
fi
echo "Nginx started successfully"

echo "=== Test: Host Header Normalization with Absolute URI ==="
echo ""
echo "Attack scenario: Sending absolute URI with spoofed Host header"
echo "  curl --request-target 'http://secure.example.com/'"
echo "       -H 'Host: malicious.attacker.com' http://127.0.0.1:$PORT/"
echo ""

RESULT=$(curl -s --max-time 5 --request-target 'http://secure.example.com/' \
    -H 'Host: malicious.attacker.com' http://127.0.0.1:$PORT/ 2>&1)
CURL_RC=$?
if [ $CURL_RC -ne 0 ]; then
    echo "ERROR: curl failed with exit code $CURL_RC"
    echo "Result: $RESULT"
    exit 1
fi

HTTP_HOST=$(echo "$RESULT" | grep -oP 'HTTP_HOST=\K.*')
HOST=$(echo "$RESULT" | grep -oP 'HOST=\K.*')
SERVER_NAME=$(echo "$RESULT" | grep -oP 'SERVER_NAME=\K.*')

echo "Backend received:"
echo "  HTTP_HOST=$HTTP_HOST"
echo "  HOST=$HOST"
echo "  SERVER_NAME=$SERVER_NAME"
echo ""

if [ "$HTTP_HOST" = "secure.example.com" ]; then
    echo "PASS: HTTP_HOST correctly normalized to URI host (RFC 9112 compliant)"
    exit 0
elif [ "$HTTP_HOST" = "malicious.attacker.com" ]; then
    echo "FAIL: HTTP_HOST contains spoofed value (VULNERABLE)"
    exit 1
else
    echo "UNKNOWN: HTTP_HOST=$HTTP_HOST"
    exit 2
fi
